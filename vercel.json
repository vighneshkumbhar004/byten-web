{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)/",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "github": {
    "silent": true
  },
  "outputDirectory": "frontend/build",
  "functions": {
    "api/*.py": {
      "excludeFiles": "{assets/**,backend/**,frontend/**,tests/**,memory/**,test_reports/**,*.md,*.pdf,*.mp4}"
    }
  }
}
